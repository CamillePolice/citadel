# --- Base de données ---
POSTGRES_PASSWORD=change-me-strong
# En dev local : connexion directe (compose expose 5432 temporairement)
# En prod : injecté depuis POSTGRES_PASSWORD contre host citadel-db
DATABASE_URL=postgres://citadel:change-me-strong@localhost:5432/citadel

# --- Dev local (sans Traefik) ---
# Permet de bypasser Authentik en développement uniquement (NODE_ENV=development)
# Ne jamais définir en production
DEV_AUTHENTIK_UID=

# --- BrickLink Price Guide ---
# Prix marché secondaire via scraping public (aucune clé requise)

# --- Rebrickable (métadonnées catalogue) ---
# Clé gratuite sur https://rebrickable.com/api/
REBRICKABLE_API_KEY=

# --- Brick Owl (fallback prix, GBP) ---
# Clé gratuite sur https://www.brickowl.com/account/api
BRICKOWL_API_KEY=

# --- eBay Finding API (prix vendus eBay France) ---
# App ID gratuit sur https://developer.ebay.com → My Account → Application Keys
EBAY_APP_ID=

# --- Worker ---
# Cron Paris time, defaut 04:00 quotidien
CRON_SCHEDULE=0 4 * * *
