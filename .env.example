# --- Base de données ---
POSTGRES_PASSWORD=change-me-strong
# En dev local : connexion directe (compose expose 5432 temporairement)
# En prod : injecté depuis POSTGRES_PASSWORD contre host citadel-db
DATABASE_URL=postgres://citadel:change-me-strong@localhost:5432/citadel

# --- Dev local (sans Traefik) ---
# Permet de bypasser Authentik en développement uniquement (NODE_ENV=development)
# Ne jamais définir en production
DEV_AUTHENTIK_UID=

# --- BrickLink Price Guide API (OAuth 1.0a) ---
# À créer sur https://www.bricklink.com/v3/api/register_consumer.page
# Whitelister l'IP publique de Scarif (ou 0.0.0.0 si IP dynamique).
BRICKLINK_CONSUMER_KEY=
BRICKLINK_CONSUMER_SECRET=
BRICKLINK_TOKEN=
BRICKLINK_TOKEN_SECRET=

# --- Rebrickable (métadonnées catalogue) ---
# Clé gratuite sur https://rebrickable.com/api/
REBRICKABLE_API_KEY=
