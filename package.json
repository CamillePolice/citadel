    "node-cron": "4.2.1",
    "nuxt": "4.4.7",
    "pinia": "^3.0.4",
    "playwright": "^1.60.0",
    "postgres": "3.4.9",
    "vue": "3.5.35",
    "vue-chartjs": "^5.3.3",
    "vue-router": "5.1.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.6.1",
    "@commitlint/config-conventional": "^19.6.0",
